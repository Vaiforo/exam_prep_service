# Скопируйте этот файл в .env и задайте свои значения.
# Не коммитьте .env в публичный репозиторий.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# Оставьте false на обычном сервере, чтобы никто не мог перезаписать банк вопросов.
ALLOW_QUESTION_IMPORT=false

# Для продакшена лучше указать домен, например:
# CORS_ORIGINS=https://exam.example.com
CORS_ORIGINS=*

# Меняйте при деплое новой версии, чтобы браузеры подтянули свежие CSS/JS.
APP_VERSION=32

REPORT_COOLDOWN_SECONDS=60
